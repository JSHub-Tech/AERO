# ============================================================================
# AERO Backend Environment Configuration
# ============================================================================
# This file contains sensitive credentials and configuration for:
# - PostgreSQL Database (Supabase)
# - Neo4j Graph Database
# - MongoDB Document Database
# - Upstash Redis Cache
# 
# ============================================================================

# ============================================================================
# DATABASE - PostgreSQL (Supabase)
# ============================================================================
# Primary relational database connection string
# Credentials: postgres user with pooled connection through Supabase
DATABASE_URL="postgresql://user:password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# ============================================================================
# GRAPH DATABASE - Neo4j (Aura)
# ============================================================================
# Neo4j cloud instance for graph data and relationships
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# Neo4j Aura instance metadata
AURA_INSTANCEID=your_instance_id
AURA_INSTANCENAME=Aero

# ============================================================================
# DOCUMENT DATABASE - MongoDB
# ============================================================================
# MongoDB cloud cluster connection string (MongoDB Atlas)
MONGODB_URI="mongodb+srv://user:password@cluster0.mongodb.net/?appName=Cluster0"

# ============================================================================
# CACHE - Upstash Redis
# ============================================================================
# Redis cache service (REST API)
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# ============================================================================
# API key - Gemini
# ============================================================================
# AI-Based Chatbot
GEMINI_API_KEY="your_gemini_api_key"
